datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PedidoStatus {
  PENDENTE
  VALIDADO
  REJEITADO
  CANCELADO
}

enum PedidoItemStatus {
  PENDENTE
  VALIDADO
  REJEITADO
  CANCELADO
  CANCELADO_POR_EXPIRACAO
}

enum PedidoItemTipo {
  COM_RECEITA
  SEM_RECEITA
  EXTRA
}

enum LinhaReceitaStatus {
  ATIVA
  EXPIRADA
}

enum ExtraStatus {
  PENDENTE
  PARCIALMENTE_REGULARIZADO
  REGULARIZADO
  EXPIRADO
}

enum RegularizacaoStatus {
  PENDENTE
  PARCIALMENTE_REGULARIZADO
  REGULARIZADO
}

enum MedicamentoTipo {
  COM_RECEITA
  SEM_RECEITA
}

enum UtenteStatus {
  ATIVO
  ARQUIVADO
}

enum UserRole {
  SANTACASA
  FARMACIA
  ADMIN
}

enum AlertaOperacionalTipo {
  PEDIDO_ENVIADO
  REGULARIZACAO_PARCIAL
  REGULARIZACAO_TOTAL
}

enum AlertaOperacionalDestino {
  FARMACIA
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)

  validatedPedidos     Pedido[]     @relation("PedidoValidatedBy")
  validatedPedidoItems PedidoItem[] @relation("PedidoItemValidatedBy")

  rejectedPedidos     Pedido[]     @relation("PedidoRejectedBy")
  rejectedPedidoItems PedidoItem[] @relation("PedidoItemRejectedBy")

  archivedUtentes Utente[] @relation("UtenteArchivedBy")

  alertaDismissals AlertaOperacionalDismissal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([role, isActive])
}

model Utente {
  id            String    @id @default(cuid())
  numero9       String    @unique @db.Char(9)
  nome          String
  isValid       Boolean   @default(true)
  invalidReason String?
  deletedAt     DateTime?

  status         UtenteStatus @default(ATIVO)
  archivedAt     DateTime?
  archivedReason String?
  archivedById   String?
  archivedBy     User?        @relation("UtenteArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)

  receitas            Receita[]
  semReceita          SemReceita[]
  extras              Extra[]
  pedidoItens         PedidoItem[]
  regularizacoes      RegularizacaoExtra[]
  medicacoesHabituais MedicacaoHabitual[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nome])
  @@index([deletedAt])
  @@index([status])
  @@index([archivedAt])
  @@index([archivedById])
  @@index([status, nome])
  @@index([deletedAt, status, nome])
  @@index([deletedAt, status, numero9])
}

model MedicacaoHabitual {
  id       String @id @default(cuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  medicamento     String
  medicamentoNorm String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([utenteId, medicamentoNorm])
  @@index([utenteId])
  @@index([medicamentoNorm])
  @@index([utenteId, createdAt])
}

model Medicamento {
  id   String          @id @default(cuid())
  nome String          @unique
  tipo MedicamentoTipo

  receitaLinhas  ReceitaLinha[]
  extras         Extra[]
  regularizacoes RegularizacaoExtra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
}

model Receita {
  id       String @id @default(cuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  numero19   String @unique @db.Char(19)
  pinAcesso6 String @db.Char(6)
  pinOpcao4  String @db.Char(4)

  linhas ReceitaLinha[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([utenteId])
  @@index([utenteId, createdAt])
}

model ReceitaLinha {
  id        String  @id @default(cuid())
  receitaId String
  receita   Receita @relation(fields: [receitaId], references: [id])

  medicamentoId  String?
  medicamentoRef Medicamento? @relation(fields: [medicamentoId], references: [id])

  nome                 String
  quantidade           Int
  quantidadeDispensada Int                @default(0)
  validade             DateTime
  status               LinhaReceitaStatus @default(ATIVA)

  pedidoItens          PedidoItem[]
  dispensas            Dispensa[]
  regularizacaoEventos RegularizacaoEvento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receitaId])
  @@index([medicamentoId])
  @@index([validade])
  @@index([status])
  @@index([status, validade])
  @@index([receitaId, status, validade])
  @@index([medicamentoId, status, validade])
}

model SemReceita {
  id       String @id @default(cuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  medicamento String
  quantidade  Int

  pedidoItens PedidoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([utenteId])
  @@index([createdAt])
  @@index([utenteId, createdAt])
}

model Extra {
  id       String @id @default(cuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  medicamentoId  String?
  medicamentoRef Medicamento? @relation(fields: [medicamentoId], references: [id])

  medicamento     String
  medicamentoNorm String?

  quantidadeSolicitada   Int
  quantidadeRegularizada Int         @default(0)
  quantidadeCancelada    Int         @default(0)
  status                 ExtraStatus @default(PENDENTE)

  pedidoItens    PedidoItem[]
  regularizacoes RegularizacaoExtra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([utenteId])
  @@index([medicamentoId])
  @@index([medicamentoNorm])
  @@index([status])
  @@index([utenteId, status])
  @@index([status, createdAt])
  @@index([medicamentoId, status])
  @@index([medicamentoNorm, status])
}

model Pedido {
  id     String       @id @default(cuid())
  numero Int          @unique @default(autoincrement())
  status PedidoStatus @default(PENDENTE)

  itens PedidoItem[]

  validatedAt   DateTime?
  validatedById String?
  validatedBy   User?     @relation("PedidoValidatedBy", fields: [validatedById], references: [id])

  rejectedAt   DateTime?
  rejectedById String?
  rejectedBy   User?     @relation("PedidoRejectedBy", fields: [rejectedById], references: [id])

  closedReason String?

  regularizacoesCriadas RegularizacaoExtra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([validatedAt])
  @@index([validatedById])
  @@index([rejectedAt])
  @@index([rejectedById])
  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@index([status, validatedAt])
  @@index([status, rejectedAt])
}

model PedidoItem {
  id       String @id @default(cuid())
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  tipo        PedidoItemTipo
  status      PedidoItemStatus @default(PENDENTE)
  medicamento String
  quantidade  Int

  receitaLinhaId String?
  receitaLinha   ReceitaLinha? @relation(fields: [receitaLinhaId], references: [id])

  semReceitaId String?
  semReceita   SemReceita? @relation(fields: [semReceitaId], references: [id])

  extraId String?
  extra   Extra?  @relation(fields: [extraId], references: [id])

  dispensas Dispensa[]

  validatedAt   DateTime?
  validatedById String?
  validatedBy   User?     @relation("PedidoItemValidatedBy", fields: [validatedById], references: [id])

  rejectedAt   DateTime?
  rejectedById String?
  rejectedBy   User?     @relation("PedidoItemRejectedBy", fields: [rejectedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pedidoId])
  @@index([utenteId])
  @@index([tipo])
  @@index([status])
  @@index([receitaLinhaId])
  @@index([semReceitaId])
  @@index([extraId])
  @@index([validatedById])
  @@index([rejectedById])
  @@index([pedidoId, status])
  @@index([utenteId, status])
  @@index([status, receitaLinhaId])
  @@index([status, semReceitaId])
  @@index([status, extraId])
  @@index([receitaLinhaId, status])
  @@index([extraId, status])
}

model Dispensa {
  id String @id @default(cuid())

  receitaLinhaId String
  receitaLinha   ReceitaLinha @relation(fields: [receitaLinhaId], references: [id])

  pedidoItemId String
  pedidoItem   PedidoItem @relation(fields: [pedidoItemId], references: [id])

  quantidade Int

  createdAt DateTime @default(now())

  @@index([receitaLinhaId])
  @@index([pedidoItemId])
  @@index([createdAt])
  @@index([receitaLinhaId, createdAt])
  @@index([pedidoItemId, createdAt])
}

model RegularizacaoExtra {
  id       String @id @default(cuid())
  utenteId String
  utente   Utente @relation(fields: [utenteId], references: [id])

  extraId String?
  extra   Extra?  @relation(fields: [extraId], references: [id])

  pedidoId String?
  pedido   Pedido? @relation(fields: [pedidoId], references: [id])

  pedidoNumero Int?

  medicamentoId  String?
  medicamentoRef Medicamento? @relation(fields: [medicamentoId], references: [id])

  medicamento     String
  medicamentoNorm String?

  quantidadeSolicitada   Int
  quantidadeRegularizada Int                 @default(0)
  status                 RegularizacaoStatus @default(PENDENTE)

  eventos RegularizacaoEvento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([utenteId])
  @@index([extraId])
  @@index([pedidoId])
  @@index([pedidoNumero])
  @@index([medicamentoId])
  @@index([medicamentoNorm])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@index([status, utenteId])
  @@index([status, pedidoNumero])
  @@index([status, medicamentoNorm])
  @@index([utenteId, status, updatedAt])
}

model RegularizacaoEvento {
  id String @id @default(cuid())

  regularizacaoId String
  regularizacao   RegularizacaoExtra @relation(fields: [regularizacaoId], references: [id])

  receitaLinhaId String
  receitaLinha   ReceitaLinha @relation(fields: [receitaLinhaId], references: [id])

  quantidade Int

  createdAt DateTime @default(now())

  @@index([regularizacaoId])
  @@index([receitaLinhaId])
  @@index([createdAt])
  @@index([regularizacaoId, createdAt])
  @@index([receitaLinhaId, createdAt])
}

model AlertaOperacional {
  id              String                    @id @default(cuid())
  tipo            AlertaOperacionalTipo
  destino         AlertaOperacionalDestino
  titulo          String
  mensagem        String
  pedidoId        String?
  regularizacaoId String?
  utenteId        String?
  metadata        Json?
  idempotencyKey  String                    @unique
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  dismissals AlertaOperacionalDismissal[]

  @@index([destino, createdAt])
  @@index([tipo, createdAt])
  @@index([pedidoId])
  @@index([regularizacaoId])
  @@index([utenteId])
}

model AlertaOperacionalDismissal {
  id          String   @id @default(cuid())
  alertaId    String
  userId      String
  dismissedAt DateTime @default(now())

  alerta AlertaOperacional @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([alertaId, userId])
  @@index([userId, dismissedAt])
}