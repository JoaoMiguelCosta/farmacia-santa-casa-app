# -----------------------------------------------------------------------------
# Farmácia Santa Casa API — Produção
# -----------------------------------------------------------------------------
# Template exclusivo para uma produção real.
#
# Não usar este ficheiro diretamente como `.env`.
# Configura os valores reais no gestor de secrets da infraestrutura.
#
# Nunca coloques secrets reais neste ficheiro.
# Este template não contém contas nem configuração de demonstração.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime da infraestrutura
# -----------------------------------------------------------------------------
# Usado pela plataforma de deploy para selecionar Node.js.
# Não é consumido por src/config/env.js.

NODE_VERSION=24

# -----------------------------------------------------------------------------
# Base de dados
# -----------------------------------------------------------------------------
# Usar uma base PostgreSQL exclusiva de produção.
# Nunca reutilizar development, testes ou staging.
# O backend bloqueia localhost quando NODE_ENV=production.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/farmacia_santacasa_production?schema=public"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------

NODE_ENV="production"

# A plataforma pode fornecer PORT automaticamente.
PORT=3001

TZ="Europe/Lisbon"
JSON_LIMIT="1mb"

# -----------------------------------------------------------------------------
# Reverse proxy / infraestrutura
# -----------------------------------------------------------------------------
# API exposta diretamente:
#   TRUST_PROXY=false
#
# API atrás de um proxy/load balancer confiável:
#   TRUST_PROXY=1
#
# Evitar TRUST_PROXY=true sem conhecer a topologia da infraestrutura.

TRUST_PROXY=1

# -----------------------------------------------------------------------------
# CORS / frontend autorizado
# -----------------------------------------------------------------------------
# Regras:
# - usar apenas origins reais;
# - não usar "*";
# - não usar localhost;
# - não incluir caminhos;
# - não colocar slash final;
# - separar múltiplas origins por vírgula.

ALLOWED_ORIGINS="https://app.exemplo.pt"

# -----------------------------------------------------------------------------
# Jobs automáticos
# -----------------------------------------------------------------------------
# Configuração inicial conservadora.
#
# Os jobs ficam desativados na instância web até existir uma decisão sobre:
# - worker único;
# - scheduler externo;
# - backups;
# - política de retenção;
# - monitorização operacional.

ENABLE_JOBS=false
ENABLE_RECEITAS_EXPIRY=false
ENABLE_HIGIENE=false
ENABLE_PURGE_HISTORY=false

# -----------------------------------------------------------------------------
# Job de higiene
# -----------------------------------------------------------------------------

HIGIENE_OFFSET_MONTHS=12
HIGIENE_ANONYMIZE=false
ALLOW_HIGIENE_ANONYMIZE=false

# -----------------------------------------------------------------------------
# Limpeza de histórico
# -----------------------------------------------------------------------------
# Não ativar sem backup e política de retenção aprovados.

PURGE_OFFSET_MONTHS=6

# -----------------------------------------------------------------------------
# Agendamentos
# -----------------------------------------------------------------------------

CRON_MONTHLY_03H="0 3 1 * *"
CRON_DAILY_03H="0 3 * * *"

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Gerar um segredo exclusivo para produção:
#
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

AUTH_JWT_SECRET="replace_with_a_real_random_production_secret"

AUTH_COOKIE_NAME="farmacia_santacasa_session"
AUTH_TOKEN_EXPIRES_IN="8h"
AUTH_COOKIE_MAX_AGE_MS=28800000

AUTH_COOKIE_SECURE=true

# Frontend e backend cross-site:
AUTH_COOKIE_SAME_SITE=none

# Se estiverem efetivamente no mesmo site, avaliar:
# AUTH_COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Rate limit de login
# -----------------------------------------------------------------------------
# O rate limit atual usa memória da instância.
# Para múltiplas instâncias, considerar armazenamento partilhado.

AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Seed inicial de produção
# -----------------------------------------------------------------------------
# Manter sempre false durante a operação normal.
#
# Durante o setup inicial controlado:
# 1. definir temporariamente ALLOW_PRODUCTION_SEED=true;
# 2. definir SEED_ADMIN_NAME, SEED_ADMIN_EMAIL e SEED_ADMIN_PASSWORD;
# 3. executar npm run prisma:seed;
# 4. confirmar o ADMIN;
# 5. voltar ALLOW_PRODUCTION_SEED para false;
# 6. remover as variáveis temporárias.
#
# Em produção, o seed cria apenas o ADMIN inicial.

ALLOW_PRODUCTION_SEED=false

# Variáveis temporárias do setup inicial:
#
# SEED_ADMIN_NAME="Administrador do Sistema"
# SEED_ADMIN_EMAIL="admin@exemplo.pt"
# SEED_ADMIN_PASSWORD="replace_with_a_strong_password_minimum_12_chars"

# -----------------------------------------------------------------------------
# Scripts manuais
# -----------------------------------------------------------------------------
# Nunca permitir scripts de teste em produção durante operação normal.

ALLOW_TEST_SCRIPTS_IN_PRODUCTION=false