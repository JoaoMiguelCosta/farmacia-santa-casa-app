# -----------------------------------------------------------------------------
# Farmácia Santa Casa API - Production Environment Example
# -----------------------------------------------------------------------------
# Copia este ficheiro apenas como referência para configurar variáveis reais
# no ambiente de produção/staging.
#
# Nunca faças commit de `.env` real.
# Nunca coloques secrets reais neste ficheiro.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Base de dados
# -----------------------------------------------------------------------------
# Usar PostgreSQL de produção/staging.
# Não usar localhost em produção real.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/farmacia_santacasa?schema=public"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------

NODE_ENV="production"
PORT=3001
TZ="Europe/Lisbon"
JSON_LIMIT="1mb"

# -----------------------------------------------------------------------------
# Reverse proxy / infraestrutura
# -----------------------------------------------------------------------------
# API exposta diretamente, sem proxy:
#   TRUST_PROXY=false
#
# API atrás de 1 proxy/load balancer, caso mais comum:
#   TRUST_PROXY=1
#
# Evitar TRUST_PROXY=true salvo se a infraestrutura controlar corretamente os
# headers X-Forwarded-*.

TRUST_PROXY=1

# -----------------------------------------------------------------------------
# CORS / Frontend origins permitidas
# -----------------------------------------------------------------------------
# Obrigatório em produção.
#
# Regras:
# - não usar "*";
# - não usar localhost;
# - separar múltiplas origins por vírgula;
# - incluir apenas domínios reais do frontend.

ALLOWED_ORIGINS="https://app.exemplo.pt,https://www.app.exemplo.pt"

# -----------------------------------------------------------------------------
# Jobs automáticos
# -----------------------------------------------------------------------------
# Em produção com apenas uma instância:
#   ENABLE_JOBS=true
#
# Em produção com múltiplas instâncias:
#   instância web:    ENABLE_JOBS=false
#   instância worker: ENABLE_JOBS=true
#
# Recomendação inicial:
#   Começar com ENABLE_JOBS=false na instância web.

ENABLE_JOBS=false

# Jobs individuais.
# Receita expiry pode correr diariamente se existir apenas uma instância worker.
# Higiene e purge exigem mais cuidado.

ENABLE_RECEITAS_EXPIRY=true
ENABLE_HIGIENE=false
ENABLE_PURGE_HISTORY=false

# -----------------------------------------------------------------------------
# Job de higiene
# -----------------------------------------------------------------------------

HIGIENE_OFFSET_MONTHS=12
HIGIENE_ANONYMIZE=false
ALLOW_HIGIENE_ANONYMIZE=false

# -----------------------------------------------------------------------------
# Job de limpeza de histórico
# -----------------------------------------------------------------------------
# Só ativar depois de existir:
# - backup automático;
# - política de retenção;
# - confirmação operacional.

PURGE_OFFSET_MONTHS=6

# -----------------------------------------------------------------------------
# Agendamento cron
# -----------------------------------------------------------------------------

CRON_MONTHLY_03H="0 3 1 * *"
CRON_DAILY_03H="0 3 * * *"

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Gerar secret real:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

AUTH_JWT_SECRET="replace_with_real_random_secret_minimum_32_chars"

AUTH_COOKIE_NAME="farmacia_santacasa_session"
AUTH_TOKEN_EXPIRES_IN="8h"
AUTH_COOKIE_MAX_AGE_MS=28800000

# Para HTTPS em produção:
AUTH_COOKIE_SECURE=true

# Se frontend e backend estiverem em domínios diferentes:
AUTH_COOKIE_SAME_SITE=none

# Se frontend e backend estiverem no mesmo domínio/site:
# AUTH_COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Rate limit de login
# -----------------------------------------------------------------------------
# O rate limit usa IP + email.
# O IP é obtido por req.ip, respeitando TRUST_PROXY.
#
# Em produção multi-instância, considerar Redis ou rate limiter externo.

AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Seed inicial
# -----------------------------------------------------------------------------
# Em produção, deixar false.
# Só mudar para true durante setup inicial controlado.
#
# Em produção o seed só cria o ADMIN inicial.
# SANTACASA e FARMACIA devem ser criados depois em Sistema > Utilizadores.
# O seed de produção não redefine password nem role de ADMIN existente.

ALLOW_PRODUCTION_SEED=false

SEED_ADMIN_EMAIL="admin@exemplo.pt"
SEED_ADMIN_PASSWORD="replace_with_strong_admin_password_minimum_12_chars"

# Mantidos apenas para referência/desenvolvimento.
# Não são usados pelo seed de produção.
SEED_SANTACASA_EMAIL="santacasa@exemplo.pt"
SEED_SANTACASA_PASSWORD="replace_with_strong_santacasa_password"

SEED_FARMACIA_EMAIL="farmacia@exemplo.pt"
SEED_FARMACIA_PASSWORD="replace_with_strong_farmacia_password"

# -----------------------------------------------------------------------------
# Seed de portefólio/demo
# -----------------------------------------------------------------------------
# Usado exclusivamente num ambiente descartável de portefólio/staging:
#   npm run prisma:seed:demo
#
# Nunca ativar numa produção real com dados ou utilizadores reais.
#
# Proteções obrigatórias:
# - ALLOW_DEMO_SEED=true;
# - DEMO_SEED_CONFIRMATION=PORTFOLIO_DEMO.
#
# Em NODE_ENV=production:
# - as três passwords são obrigatórias;
# - cada password deve ter pelo menos 12 caracteres;
# - as passwords de exemplo são rejeitadas;
# - os emails demo não podem reutilizar contas do seed inicial.
#
# Depois de executar:
# - voltar ALLOW_DEMO_SEED para false;
# - limpar DEMO_SEED_CONFIRMATION;
# - remover as passwords do ambiente do serviço.

ALLOW_DEMO_SEED=false
DEMO_SEED_CONFIRMATION=""

DEMO_ADMIN_NAME="Administrador Demo"
DEMO_ADMIN_EMAIL="demo.admin@sistema.local"
DEMO_ADMIN_PASSWORD="replace_with_strong_demo_admin_password_minimum_12_chars"

DEMO_SANTACASA_NAME="Santa Casa Demo"
DEMO_SANTACASA_EMAIL="demo.santacasa@sistema.local"
DEMO_SANTACASA_PASSWORD="replace_with_strong_demo_santacasa_password_minimum_12_chars"

DEMO_FARMACIA_NAME="Farmácia Demo"
DEMO_FARMACIA_EMAIL="demo.farmacia@sistema.local"
DEMO_FARMACIA_PASSWORD="replace_with_strong_demo_farmacia_password_minimum_12_chars"

# -----------------------------------------------------------------------------
# Segurança adicional para scripts manuais
# -----------------------------------------------------------------------------

ALLOW_TEST_SCRIPTS_IN_PRODUCTION=false
