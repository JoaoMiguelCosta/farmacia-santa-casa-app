# -----------------------------------------------------------------------------
# Farmácia Santa Casa API — Staging / Portefólio
# -----------------------------------------------------------------------------
# Template para o ambiente público de demonstração.
#
# O serviço executa NODE_ENV=production para reproduzir as proteções reais,
# mas usa base de dados, domínios, secrets e contas separados de produção.
#
# Nunca coloques passwords ou secrets reais neste ficheiro.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime da infraestrutura
# -----------------------------------------------------------------------------

NODE_VERSION=24

# -----------------------------------------------------------------------------
# Base de dados de staging
# -----------------------------------------------------------------------------
# Usar uma base PostgreSQL exclusiva do ambiente demo.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/farmacia_santacasa_staging?schema=public"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------

NODE_ENV="production"

# Normalmente fornecida automaticamente pela plataforma.
PORT=3001

TZ="Europe/Lisbon"
JSON_LIMIT="1mb"

# -----------------------------------------------------------------------------
# Reverse proxy
# -----------------------------------------------------------------------------
# Render utiliza proxy antes da aplicação.

TRUST_PROXY=1

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

ALLOWED_ORIGINS="https://farmacia-santacasa-frontend-staging.onrender.com"

# -----------------------------------------------------------------------------
# Jobs
# -----------------------------------------------------------------------------
# No ambiente público de demonstração, os jobs ficam desativados para evitar
# alterações automáticas ao dataset fictício.

ENABLE_JOBS=false
ENABLE_RECEITAS_EXPIRY=false
ENABLE_HIGIENE=false
ENABLE_PURGE_HISTORY=false

HIGIENE_OFFSET_MONTHS=12
HIGIENE_ANONYMIZE=false
ALLOW_HIGIENE_ANONYMIZE=false

PURGE_OFFSET_MONTHS=6

CRON_MONTHLY_03H="0 3 1 * *"
CRON_DAILY_03H="0 3 * * *"

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Gerar um segredo exclusivo para staging.
# Nunca reutilizar o segredo de uma futura produção real.

AUTH_JWT_SECRET="replace_with_a_random_staging_secret"

AUTH_COOKIE_NAME="farmacia_santacasa_session"
AUTH_TOKEN_EXPIRES_IN="8h"
AUTH_COOKIE_MAX_AGE_MS=28800000

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none

# -----------------------------------------------------------------------------
# Rate limit
# -----------------------------------------------------------------------------

AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Seed inicial
# -----------------------------------------------------------------------------
# O ambiente demo usa o seed de portefólio separado.
# O seed inicial de produção permanece bloqueado.

ALLOW_PRODUCTION_SEED=false

# -----------------------------------------------------------------------------
# Seed demo protegido
# -----------------------------------------------------------------------------
# Comando:
#
# npm run prisma:seed:demo
#
# Durante a operação normal:
#
# ALLOW_DEMO_SEED=false
# DEMO_SEED_CONFIRMATION=""
#
# Para uma reposição controlada:
#
# ALLOW_DEMO_SEED=true
# DEMO_SEED_CONFIRMATION=PORTFOLIO_DEMO
#
# Depois da reposição, voltar imediatamente ao estado bloqueado.

ALLOW_DEMO_SEED=false
DEMO_SEED_CONFIRMATION=""

DEMO_ADMIN_NAME="Administrador Demo"
DEMO_ADMIN_EMAIL="demo.admin@sistema.local"
DEMO_ADMIN_PASSWORD="replace_with_strong_demo_admin_password_minimum_12_chars"

DEMO_SANTACASA_NAME="Santa Casa Demo"
DEMO_SANTACASA_EMAIL="demo.santacasa@sistema.local"
DEMO_SANTACASA_PASSWORD="replace_with_strong_demo_santacasa_password_minimum_12_chars"

DEMO_FARMACIA_NAME="Farmácia Demo"
DEMO_FARMACIA_EMAIL="demo.farmacia@sistema.local"
DEMO_FARMACIA_PASSWORD="replace_with_strong_demo_farmacia_password_minimum_12_chars"

# -----------------------------------------------------------------------------
# Scripts manuais
# -----------------------------------------------------------------------------

ALLOW_TEST_SCRIPTS_IN_PRODUCTION=false

# -----------------------------------------------------------------------------
# Smoke test remoto — variáveis locais
# -----------------------------------------------------------------------------
# Estas variáveis são usadas no computador do programador, não são necessárias
# no serviço backend do Render.
#
# STAGING_SMOKE_CONFIRMATION=STAGING_READ_ONLY
# STAGING_API_BASE_URL=https://farmacia-santacasa-backend-staging.onrender.com/api
# STAGING_FRONTEND_ORIGIN=https://farmacia-santacasa-frontend-staging.onrender.com
#
# O smoke test também precisa das três DEMO_*_PASSWORD na sessão local:
#
# npm run test:staging:auth