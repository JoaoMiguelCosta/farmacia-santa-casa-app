# -----------------------------------------------------------------------------
# Frontend — produção
# -----------------------------------------------------------------------------
# Template de referência para configurar a plataforma de deploy.
#
# Este ficheiro não é carregado automaticamente pelo Vite.
# Define VITE_API_BASE_URL diretamente na plataforma ou cria localmente
# `.env.production` sem o versionar.
#
# Nunca coloques secrets no frontend.
# Todas as variáveis VITE_* ficam disponíveis no bundle do browser.
# -----------------------------------------------------------------------------

VITE_API_BASE_URL="https://api.example.pt/api"
